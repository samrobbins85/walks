---
import { Icon } from "astro-icon/components";
import type { EnrichedTransportLeg } from "../utils/transportEnrichment";
import TransportLeg from "./transportLeg.astro";

interface Props {
  outbound?: EnrichedTransportLeg[];
  return?: EnrichedTransportLeg[];
}

const { outbound, return: returnLegs } = Astro.props;
---

<div>
  <h2 class="text-sm font-medium text-slate-400 uppercase tracking-wider mb-4">
    Transport
  </h2>
  <div class="grid md:grid-cols-2 gap-6">
    {
      outbound && outbound.length > 0 && (
        <div>
          <h3 class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-x-1.5">
            <Icon name="lucide:arrow-right" class="size-3.5" />
            Outbound
          </h3>
          <div class="flex flex-col gap-y-2">
            {outbound.map((leg) => (
              <TransportLeg leg={leg} />
            ))}
          </div>
        </div>
      )
    }
    {
      returnLegs && returnLegs.length > 0 && (
        <div>
          <h3 class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-x-1.5">
            <Icon name="lucide:arrow-left" class="size-3.5" />
            Return
          </h3>
          <div class="flex flex-col gap-y-2">
            {returnLegs.map((leg) => (
              <TransportLeg leg={leg} />
            ))}
          </div>
        </div>
      )
    }
  </div>
</div>
