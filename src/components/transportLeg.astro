---
import { Icon } from "astro-icon/components";
import type { EnrichedTransportLeg } from "../utils/transportEnrichment";

interface Props {
  leg: EnrichedTransportLeg;
}

const { leg } = Astro.props;
---

<div class="flex items-center gap-x-2 p-2.5 rounded-lg">
  <div class="w-5 flex-shrink-0 flex items-center justify-center">
    {
      leg.mode === "train" ? (
        <img
          src="/img/National_Rail_logo.svg"
          alt="National Rail"
          class="w-5 h-auto"
        />
      ) : leg.mode === "metro" ? (
        <img
          src="/img/tyne_wear_metro.svg"
          alt="Tyne & Wear Metro"
          class="w-5 h-auto"
        />
      ) : (
        <Icon name="lucide:bus" class="size-5 text-slate-400" />
      )
    }
  </div>
  {
    leg.url ? (
      <a
        href={leg.url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center"
      >
        <span
          class="px-2 py-0.5 rounded text-xs font-medium"
          style={`background-color: ${leg.background}; color: ${leg.foreground};`}
        >
          {leg.line}
        </span>
      </a>
    ) : leg.crs_from && leg.crs_to ? (
      <a
        href="#"
        data-crs-from={leg.crs_from}
        data-crs-to={leg.crs_to}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center"
      >
        <span
          class="px-2 py-0.5 rounded text-xs font-medium"
          style={`background-color: ${leg.background}; color: ${leg.foreground};`}
        >
          {leg.line}
        </span>
      </a>
    ) : (
      <span
        class="px-2 py-0.5 rounded text-xs font-medium"
        style={`background-color: ${leg.background}; color: ${leg.foreground};`}
      >
        {leg.line}
      </span>
    )
  }
  <span class="text-sm text-slate-600">
    {leg.from} → {leg.to}
  </span>
</div>

<script>
  document
    .querySelectorAll<HTMLAnchorElement>("a[data-crs-from]")
    .forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const origin = link.dataset.crsFrom;
        const destination = link.dataset.crsTo;
        const now = new Date();
        now.setMinutes(now.getMinutes() + 1);
        const roundedMin = Math.ceil(now.getMinutes() / 5) * 5;
        if (roundedMin === 60) {
          now.setHours(now.getHours() + 1);
          now.setMinutes(0);
        } else {
          now.setMinutes(roundedMin);
        }
        const date =
          String(now.getDate()).padStart(2, "0") +
          String(now.getMonth() + 1).padStart(2, "0") +
          String(now.getFullYear()).slice(-2);
        const hour = String(now.getHours()).padStart(2, "0");
        const min = String(now.getMinutes()).padStart(2, "0");
        window.open(
          `https://www.nationalrail.co.uk/journey-planner/?type=single&origin=${origin}&destination=${destination}&leavingType=departing&leavingDate=${date}&leavingHour=${hour}&leavingMin=${min}&adults=1&extraTime=0#O`,
          "_blank",
        );
      });
    });
</script>
